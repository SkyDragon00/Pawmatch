<% content_for :title, "Pawmatch Messages" %>
<% content_for :body_class, "bg-background text-on-background min-h-screen flex flex-col" %>

<% content_for :head do %>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "on-primary-fixed": "#3d0016",
            "surface-container-highest": "#fbdbe3",
            error: "#ba1a1a",
            "on-secondary-fixed-variant": "#5c3f44",
            "surface-bright": "#fff8f8",
            "on-primary-fixed-variant": "#8b0038",
            "primary-fixed-dim": "#ffb1c4",
            "tertiary-container": "#f0dbff",
            "on-error": "#ffffff",
            background: "#fff8f8",
            "on-tertiary-container": "#24005a",
            "on-surface": "#25191c",
            primary: "#bc004c",
            "on-primary-container": "#400015",
            "secondary-fixed": "#ffd9de",
            "on-secondary": "#ffffff",
            "primary-fixed": "#ffd9e0",
            outline: "#847376",
            "on-error-container": "#93000a",
            "error-container": "#ffdad6",
            "inverse-on-surface": "#ffebef",
            "secondary-container": "#f7d8dd",
            "on-tertiary": "#ffffff",
            secondary: "#75565b",
            "inverse-primary": "#ffb1c4",
            "tertiary-fixed-dim": "#d9bdf6",
            "on-tertiary-fixed-variant": "#543b74",
            tertiary: "#6c538c",
            "surface-container-high": "#f6dce1",
            "surface-dim": "#e7d6d9",
            "on-secondary-fixed": "#2b1519",
            "surface-tint": "#bc004c",
            "inverse-surface": "#3b2e31",
            "secondary-fixed-dim": "#e5bdc2",
            "tertiary-fixed": "#f0dbff",
            "on-surface-variant": "#524346",
            "on-tertiary-fixed": "#24005a",
            "surface-container": "#fae3e7",
            "surface-container-low": "#fff0f2",
            "on-background": "#25191c",
            "outline-variant": "#d6c2c5",
            "on-primary": "#ffffff",
            surface: "#fff8f8",
            "primary-container": "#ffd9e0",
            "surface-container-lowest": "#ffffff",
            "on-secondary-container": "#2b1519",
            "surface-variant": "#f3dde1"
          },
          borderRadius: {
            DEFAULT: "1.5rem",
            lg: "2.5rem",
            xl: "4rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Plus Jakarta Sans"],
            body: ["Plus Jakarta Sans"],
            label: ["Plus Jakarta Sans"]
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .chat-scroll::-webkit-scrollbar { width: 4px; }
    .chat-scroll::-webkit-scrollbar-track { background: transparent; }
    .chat-scroll::-webkit-scrollbar-thumb { background: #d6c2c5; border-radius: 10px; }
    .paw-pattern {
      background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 20a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm7 2a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm-14 0a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm7 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z' fill='%23bc004c' fill-opacity='0.04' fill-rule='evenodd'/%3E%3C/svg%3E");
    }
  </style>
<% end %>

<nav class="bg-rose-50/70 dark:bg-rose-950/70 backdrop-blur-xl shadow-sm shadow-rose-200/50 dark:shadow-none sticky top-0 w-full z-50">
  <div class="flex justify-between items-center w-full px-6 py-4 max-w-7xl mx-auto">
    <a class="text-2xl font-black text-rose-700 dark:text-rose-300 tracking-tighter" href="<%= root_path %>">Pawmatch</a>
    <div class="hidden md:flex items-center gap-8 font-['Plus_Jakarta_Sans'] tracking-tight">
      <a class="text-rose-400 dark:text-rose-500 font-medium hover:text-rose-800 dark:hover:text-rose-200 transition-all duration-300 cursor-pointer" href="<%= root_path %>">Discover</a>
      <a class="text-rose-700 dark:text-rose-300 border-b-2 border-rose-600 dark:border-rose-400 pb-1 font-bold transition-all duration-300 cursor-pointer" href="<%= messages_path %>">Chat</a>
      <a class="text-rose-400 dark:text-rose-500 font-medium hover:text-rose-800 dark:hover:text-rose-200 transition-all duration-300 cursor-pointer" href="#">Favorites</a>
    </div>
    <div class="flex items-center gap-4">
      <button class="p-2 text-rose-600 dark:text-rose-400 hover:text-rose-800 dark:hover:text-rose-200 active:scale-95 transition-all" type="button">
        <span class="material-symbols-outlined">pets</span>
      </button>
      <a href="<%= profile_path %>">
        <img alt="User profile" class="w-10 h-10 rounded-full object-cover ring-2 ring-primary-container active:scale-95 cursor-pointer transition-all" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBhhwiLtJmA0kiGaHggA-QsmmHQgcjoFDOSDkToyL3Uw6rkLLOGh5iy4GqLI16Q9kXiFZGb6dU0VFOR3NxnBGNKhLKqgYCSFQI8FThoKqrsUur0sh8MDJxu1K_NXi7yBkT1Imy2nijfCDYrbmGmgj3W5g-igxOIArWVqYJVZ6K7E0o0NBPFWNSrYYq1VMF3_CIsmtvYBkFK3HgNnADO7HFis9h6RJb6-2C7iEUrbQcQHeQ7kv3xRFZvW1Bk-RR13-fmqhJWBikO8Co"/>
      </a>
    </div>
  </div>
</nav>

