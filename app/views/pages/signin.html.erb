<% content_for :title, "Sign in to Pawmatch" %>
<% content_for :body_class, "paw-page" %>

<main class="paw-container" style="padding: 2rem 0 3rem;">
  <div class="paw-auth-shell" style="grid-template-columns: 0.9fr 1.1fr;">
    <section class="paw-auth-panel">
      <a class="paw-brand" href="<%= root_path %>">
        <span class="paw-brand__mark">
          <%= image_tag "/Pawmatch%20Logo.png", alt: "Pawmatch logo", class: "paw-brand__logo" %>
        </span>
        <span>Pawmatch</span>
      </a>

      <h1>Sign in and continue matching.</h1>
      <p>
        Use your account details to get back to your dog’s matches, favorites, and profile.
      </p>
      <div class="paw-card">
        <h3>New here?</h3>
        <p>Create your account first so you can add your dog’s photo and matching preferences.</p>
        <p><a class="paw-button paw-button--primary" href="<%= signup_path %>">Create account</a></p>
      </div>
    </section>

    <section class="paw-form-panel">
      <form class="paw-form">
        <div>
          <label class="paw-label" for="signin_email">Email</label>
          <input class="paw-field" id="signin_email" type="email" placeholder="you@example.com" required>
        </div>

        <div>
          <label class="paw-label" for="signin_password">Password</label>
          <input class="paw-field" id="signin_password" type="password" placeholder="Your password" required>
        </div>

        <div class="paw-actions-row">
          <a class="paw-button paw-button--ghost" href="<%= root_path %>">Back to home</a>
          <button class="paw-button paw-button--primary" type="submit">Sign in</button>
        </div>
      </form>
    </section>
  </div>
</main>
