      </div>

      <div class="flex items-center gap-4 p-4 rounded-full hover:bg-surface-container transition-all cursor-pointer">
        <img class="w-14 h-14 rounded-full object-cover" alt="Pomeranian profile" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBiSNKImrkhNs_Len-DZFAf87EUeITGiFUq4qnerZB0H-M5KmL8ZNWlDbdcxFFAFQfq5wrFoFtlfHFBS7BRId-XNodcNPBD0z2IbsvxmQxpwau2GN_8xsBoAZdNnoYEs2Ucse3VmIwKw_IwoL9SULiLSggz86FWecC1FocUX32SQpSaw8HDobTux3WEDqzfymVfz4xQQdpVfmp0scrm0926Dm6YgY6QF-rgUHhejz1Z6D0B6xHsOyVYOqb3bKG1m2w3Llh2XFusQSE"/>
        <div class="flex-grow min-w-0">
