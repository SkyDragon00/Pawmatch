    <div class="text-lg font-bold text-rose-700 dark:text-rose-300">Pawmatch</div>
    <div class="flex gap-6">
      <a class="text-rose-400 dark:text-rose-500 hover:underline decoration-rose-300 underline-offset-4 opacity-80 hover:opacity-100 transition-opacity" href="<%= root_path %>">Discover</a>
      <a class="text-rose-700 dark:text-rose-300 font-semibold hover:underline decoration-rose-300 underline-offset-4 opacity-80 hover:opacity-100 transition-opacity" href="<%= messages_path %>">Chat</a>
      <a class="text-rose-400 dark:text-rose-500 hover:underline decoration-rose-300 underline-offset-4 opacity-80 hover:opacity-100 transition-opacity" href="#">Favorites</a>
    </div>
    <div class="text-rose-400 dark:text-rose-500 opacity-60">© 2024 Pawmatch. Designed with affection.</div>
  </div>
</footer>
