<div class="md:hidden fixed bottom-0 w-full bg-rose-50/90 backdrop-blur-xl flex justify-around items-center h-20 border-t border-rose-100 z-50">
  <a href="<%= root_path %>" class="flex flex-col items-center gap-1 text-rose-400">
    <span class="material-symbols-outlined">explore</span>
    <span class="text-[10px] font-bold">Discover</span>
  </a>
  <a href="<%= messages_path %>" class="flex flex-col items-center gap-1 text-rose-700">
    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">chat_bubble</span>
    <span class="text-[10px] font-bold">Chat</span>
  </a>
  <button class="flex flex-col items-center gap-1 text-rose-400" type="button">
    <span class="material-symbols-outlined">favorite</span>
    <span class="text-[10px] font-bold">Favorites</span>
  </button>
  <a href="<%= profile_path %>" class="flex flex-col items-center gap-1 text-rose-400">
    <span class="material-symbols-outlined">person</span>
    <span class="text-[10px] font-bold">Profile</span>
  </a>
</div>

<footer class="hidden md:block w-full py-12 bg-rose-50 dark:bg-rose-950 border-t border-rose-100 dark:border-rose-900">
