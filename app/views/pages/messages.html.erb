    </header>

    <div class="flex-grow overflow-y-auto chat-scroll p-8 space-y-6">
      <div class="flex justify-center">
        <span class="px-5 py-1.5 bg-surface-container-high text-[10px] font-extrabold uppercase tracking-widest text-on-surface-variant rounded-full">Today</span>
      </div>

      <div class="flex items-end gap-3 max-w-[80%]">
        <img class="w-8 h-8 rounded-full object-cover shadow-sm" alt="Puppy profile avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCBRcgUur0e5ujjyJ_K-744aZgCziH26CiKCBlOqVpZy34jYOjr3gNUcxcsCbaIG2IqLZ72V5SElgkgIy2hPslDTQNMm-Q8r8QF7O7NJ2L3-Ba83wkefZIXogTQUT7M9ENfdl9pf1jCS6RVX5-POB0zpHkqILpMfmnDq0uMxM3B8KT96C6O4_8Y68a7UB5wPywZpfslWxd8z8LfZy7dN2PU1q5wOXxs9UlPialkGnNVlgZHcAMWPdZ_afKY8SpIpJYFewuztN0JGHI"/>
        <div class="space-y-1">
