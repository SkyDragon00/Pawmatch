        View All Photos <span class="material-symbols-outlined">arrow_forward</span>
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 h-[600px]">
      <div class="md:col-span-2 md:row-span-2 rounded-[2rem] overflow-hidden bg-surface-container-high group">
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Close up of a golden retriever's expressive face" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB6PXSBpt9QlqHbXcpCcxSNOvvvgts0JfecVd9D-e_RDKUgEZfOnuMne3DgCbHpTLPj0cThnZwRN1n5FTbvZaBU-bcisulxNNu1eLpma80bPu2uZw2T7DFemujCpP7olMLbH2PnI6HSF7F0jvowo_rlXFy-ttvhWZqU3d1CiZ0na0f-pwUF0qpOz32z9RtD3wz58s8XINj4hr3CQex3Vwz_oqWUrGP34SNWD3HloAGapaVVRTBDrSeWRBBGfsDiZEchdsaZjUs-Uk8"/>
      </div>
      <div class="rounded-[2rem] overflow-hidden bg-surface-container-high group">
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Happy golden retriever running through a field of wildflowers" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDzlWyFKATbYA3gORWNg0qad4-1kZBW2Q8R1kLRFqEqKbukQsqYdoAXtLX2WSZH-VqHy-M3c9VmhkQ_VKID_6dX0PwnHNc9NqgdGoSRfePt7aBbBqSdyrr_I9UcE7HhaYVNRJUpWZISXKKG498TlCH45czE1cHiYGnvxCU3bepv0VcTlU_lIxZYkZU82jDeEu95gEWMK_m9oRUR1XTY3TgT0Tl0TbV60y-v5b-oA4PXYaKIlymP2Q0CI5rvFTClljUKlEQYCEj-yBc"/>
      </div>
      <div class="rounded-[2rem] overflow-hidden bg-surface-container-high group">
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Golden retriever puppy sleeping peacefully on a colorful blanket" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCF9m6NltrkMqyNbrWUnftBOIrl0UoUy71kcjlNDL2hjt-O5Lke8mGsaWk7FCAaK_EnNibZU5ztsAgp-d6PyFfEP0351sazfE2km4jRkN1FA2H3bxeAHXy_D82AFJpVBS9AAvlgEed-oNe5-oLox5s7OinuTCU-ZvUxDg2NA4besoBSS8Q7oWdCvRw4BTj318N7X06pvoIoaaY59BOAugRdMxTuPl-HglVQ2ExmPXk1Q0ZiQITM7XHOkmPqzT-_OYgkAV8bTHotd4w"/>
      </div>
      <div class="md:col-span-2 rounded-[2rem] overflow-hidden bg-surface-container-high group">
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Golden retriever standing on a wooden dock overlooking a calm lake at dawn" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAmD2210l8jRwKgWiDCipmQujF8aooYUT4wPeFZqqQQW4xgT_oZZTeLSQm7CAubBbaewgoB17Kt0zGKNBEXqUAaaFFiM0vDwFzPTOCrY_W9F-Ifti0jmaUHRnKcFHVlybEGGWUVvCcMmkWYbbWnZ_rt94kmKGxGZaGjHsJoKrrQk5UpZXXf3rjh6ANbvI2zJIH0wHSs3G_8g38nWPqqdnjrzuanVnT0I4X19nARmeo6mEH7tNKxLaObnCgHh2pOSfC1kDy8X8VNdic"/>
      </div>
    </div>
  </section>
</main>

<footer class="bg-rose-50 dark:bg-rose-950 w-full py-12 border-t border-rose-100 dark:border-rose-900">
  <div class="flex flex-col md:flex-row justify-between items-center px-8 max-w-7xl mx-auto gap-6 font-['Plus_Jakarta_Sans'] text-sm">
    <div class="flex flex-col items-center md:items-start gap-2">
      <div class="text-lg font-bold text-rose-700 dark:text-rose-300">Pawmatch</div>
      <p class="text-rose-400 dark:text-rose-500 text-center md:text-left">© 2024 Pawmatch. Designed with affection.</p>
    </div>
    <div class="flex gap-6">
      <a class="text-rose-600 dark:text-rose-400 font-semibold opacity-80 hover:opacity-100 hover:underline decoration-rose-300 underline-offset-4 transition-all" href="<%= root_path %>">Discover</a>
      <a class="text-rose-600 dark:text-rose-400 font-semibold opacity-80 hover:opacity-100 hover:underline decoration-rose-300 underline-offset-4 transition-all" href="<%= messages_path %>">Chat</a>
      <a class="text-rose-600 dark:text-rose-400 font-semibold opacity-80 hover:opacity-100 hover:underline decoration-rose-300 underline-offset-4 transition-all" href="#">Favorites</a>
      <a class="text-rose-600 dark:text-rose-400 font-semibold opacity-80 hover:opacity-100 hover:underline decoration-rose-300 underline-offset-4 transition-all" href="#">Privacy</a>
      <a class="text-rose-600 dark:text-rose-400 font-semibold opacity-80 hover:opacity-100 hover:underline decoration-rose-300 underline-offset-4 transition-all" href="#">Terms</a>
    </div>
    <div class="flex gap-4">
      <div class="w-8 h-8 rounded-full bg-rose-100 dark:bg-rose-900/50 flex items-center justify-center text-rose-600 dark:text-rose-400 cursor-pointer hover:scale-110 transition-all">
        <span class="material-symbols-outlined text-sm">public</span>
      </div>
      <div class="w-8 h-8 rounded-full bg-rose-100 dark:bg-rose-900/50 flex items-center justify-center text-rose-600 dark:text-rose-400 cursor-pointer hover:scale-110 transition-all">
        <span class="material-symbols-outlined text-sm">share</span>
      </div>
    </div>
  </div>
</footer>
