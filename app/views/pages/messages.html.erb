            <h3 class="font-bold text-on-background truncate">Max</h3>
            <span class="text-[10px] text-on-surface-variant/60">Monday</span>
          </div>
          <p class="text-sm text-on-surface-variant truncate">How old is your pup? 🦴</p>
        </div>
      </div>
